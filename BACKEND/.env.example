# ─────────────────────────────────────────────────────────────────
#  BACKEND — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL Database Connection URL
# Local PostgreSQL:  postgresql://postgres:yourpassword@localhost:5432/ecosphere?schema=public
# Neon (cloud):      postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/ecosphere?schema=public

# Secret key used to sign and verify JWT tokens
# Must be a random string of at least 32 characters — never use the example value in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_strong_random_secret_at_least_32_chars

# Port the Express server listens on
PORT=5000

# Environment mode: development | production | test
NODE_ENV=development

# Allowed frontend origin — used by CORS in production to whitelist the frontend
FRONTEND_URL=http://localhost:3000
